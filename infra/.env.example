# Copy to infra/.env. These are the backing-service credentials for
# docker-compose (separate from api/.env, which holds the API's own config).
# Defaults below match api/.env.example's DATABASE_URL so local dev works
# with zero edits — change all of them before this ever runs on the VM.

POSTGRES_USER=scribeflow
POSTGRES_PASSWORD=scribeflow
POSTGRES_DB=scribeflow

RABBITMQ_USER=scribeflow
RABBITMQ_PASSWORD=scribeflow

CLICKHOUSE_USER=scribeflow
CLICKHOUSE_PASSWORD=scribeflow
CLICKHOUSE_DB=scribeflow
