# bot/ ships two processes from one package (tickets 5.2-5.5): the meeting
# bot itself (Playwright + Xvfb + PulseAudio, runs inside bot/Dockerfile's
# image, one ephemeral container per meeting) and the orchestrator (a small
# always-on Node service, bot/orchestrator.Dockerfile, that spawns/tracks/
# reaps those containers). Copy to bot/.env for local runs of either with
# `pnpm bot` / `pnpm orchestrator`; on the VM these come from the single
# .env injected by infra/compose.yml (docs/infrastructure.md).

# --- bot container (docs/meet-bot.md's config table) ------------------------
# In production BOT_CONFIG (meeting id, Meet URL, session token, etc.) is
# injected per-session by the orchestrator, not set here — see
# bot/src/orchestrator/spawn.ts. Set it yourself only for local `pnpm bot`
# runs against a real Meet URL, e.g.:
#   BOT_CONFIG={"tenantId":"...","meetingId":"...","sessionId":"...","sessionToken":"...","meetUrl":"https://meet.google.com/xxx-yyyy-zzz","orchestratorUrl":"http://localhost:8080","platform":"meet"}
BOT_CONFIG=

BOT_ADMISSION_TIMEOUT_S=300
BOT_JOIN_REQUEST_ATTEMPTS=3
BOT_LONE_PARTICIPANT_S=60
BOT_NO_ONE_JOINED_S=600
BOT_MAX_DURATION_S=7200
BOT_SEGMENT_S=300
BOT_DISPLAY_NAME=ScribeFlow Notetaker
# Never set to 1 in prod compose — x11vnc/websockify are 5.6's debugging aid.
BOT_DEBUG_VNC=0
# Signed-in-profile fallback for orgs that block anonymous joiners (D68) —
# unset by default (anonymous join).
BOT_STORAGE_STATE_PATH=
BOT_RECORDING_DIR=/rec

# --- orchestrator (ticket 5.5) -----------------------------------------------
DATABASE_URL=postgres://scribeflow:scribeflow@localhost:55432/scribeflow
RABBITMQ_URL=amqp://scribeflow:scribeflow@localhost:5672

# Cloudflare R2 — same scoped token as the API's/workers' (D70: the
# orchestrator is the only bot-adjacent process that ever holds this).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scribeflow
R2_ENDPOINT=
UPLOAD_URL_TTL_S=900

# D72: the RAM budget affords 2; default 1 by explicit decision (D72) — see
# docs/infrastructure.md.
BOT_MAX_CONCURRENT=1
BOT_IMAGE=scribeflow-bot:latest
# Matches api/src/queue/topology.ts's BOT_SPAWN_TTL_MS (30 min) — the queue
# TTL and this app-level staleness check are belt-and-suspenders (D31).
BOT_SPAWN_TTL_S=1800

# How bot containers reach this process on the compose network (D70) — not
# itself one of docs/meet-bot.md's config-table vars (those are what gets
# injected *into* the bot container); CONTROL_PLANE_HOST is what
# BOT_CONFIG.orchestratorUrl gets built from.
CONTROL_PLANE_PORT=8080
CONTROL_PLANE_HOST=orchestrator

BOT_HEARTBEAT_TIMEOUT_S=60
BOT_REAPER_INTERVAL_S=15

DOCKER_SOCKET_PATH=/var/run/docker.sock
# Compose network name so a freshly `docker run` bot container can resolve
# CONTROL_PLANE_HOST — leave unset for a bare local `docker run` (default
# bridge network), set to the compose project's network on the VM.
DOCKER_NETWORK=
