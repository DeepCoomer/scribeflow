# See docs/infrastructure.md for where each value comes from.

NODE_ENV=development
PORT=3000

# Postgres (infra/compose.yml service `postgres`, mapped to host port 55432
# to avoid colliding with a locally-installed Postgres on the default 5432)
DATABASE_URL=postgres://scribeflow:scribeflow@localhost:55432/scribeflow

# Auth
JWT_SECRET=dev-secret-change-me
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/auth/google/callback

# RabbitMQ (infra/compose.yml service `rabbitmq`)
RABBITMQ_URL=amqp://scribeflow:scribeflow@localhost:5672

# Cloudflare R2 (docs/infrastructure.md §Provisioning step 5) — scoped API
# token for the `scribeflow` bucket only. Leave blank to boot without object
# storage (upload endpoints return 503). R2_ENDPOINT is normally derived from
# R2_ACCOUNT_ID; set it explicitly only for S3-compatible stand-ins.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scribeflow
R2_ENDPOINT=
UPLOAD_URL_TTL_S=900

# Comma-separated browser origins allowed by CORS (add the Vercel domain
# when going live at 1.7).
CORS_ORIGINS=http://localhost:5173

# Ticket 3.4 — Resend free tier (100/day). Leave blank to boot with the
# summary-email endpoint disabled (503), same pattern as R2 above; the
# summary/action-items dashboard experience works either way (CLAUDE.md:
# "optional, via free Resend tier or skip").
RESEND_API_KEY=
RESEND_FROM_EMAIL=ScribeFlow <notifications@scribeflow.deepcoomer.dev>

# Ticket 3.6 — the RAG chat's answer step (same Groq account as the workers'
# extraction pass, workers/.env.example, but its own key here since the API
# doesn't share a process with the Python workers). Leave blank to boot with
# /chat disabled (503), same "optional, or skip" pattern as RESEND_API_KEY
# above. Retrieval itself needs no key — see EMBEDDING_QUERY_MODEL below.
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Query-time embedding (D64): must stay the transformers.js/ONNX twin of
# workers/.env.example's EMBEDDING_MODEL — same weights, different runtime —
# or the RAG chat's query vectors land in a different space than the stored
# ones. No API key: downloads once from the HF hub and runs in-process.
EMBEDDING_QUERY_MODEL=Xenova/all-MiniLM-L6-v2
