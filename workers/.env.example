# Worker configuration — see docs/infrastructure.md for where each value
# comes from. Copy to workers/.env for local runs; on the VM these come from
# the single .env injected by infra/compose.yml.

RABBITMQ_URL=amqp://scribeflow:scribeflow@localhost:5672
# Host port 55432 locally (compose maps it there); inside compose the workers
# get postgres:5432 via the service network instead.
DATABASE_URL=postgres://scribeflow:scribeflow@localhost:55432/scribeflow

# Cloudflare R2 — same scoped token as the API's (read access is enough for
# workers). R2_ENDPOINT normally derives from the account id; set explicitly
# only for S3-compatible stand-ins.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scribeflow
R2_ENDPOINT=

# Groq (docs/infrastructure.md free-tier limits; calls go through the shared
# rate limiter, D24)
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# D22 fallback switch: groq | local. "local" runs LOCAL_WHISPER_CMD (a
# whisper.cpp-style CLI); {input} and {output_base} are substituted, and
# {output_base}.json must contain verbose_json-compatible output.
TRANSCRIBE_BACKEND=groq
LOCAL_WHISPER_CMD=

LOG_LEVEL=INFO
