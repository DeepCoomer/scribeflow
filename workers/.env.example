# Worker configuration — see docs/infrastructure.md for where each value
# comes from. Copy to workers/.env for local runs; on the VM these come from
# the single .env injected by infra/compose.yml.

RABBITMQ_URL=amqp://scribeflow:scribeflow@localhost:5672
# Host port 55432 locally (compose maps it there); inside compose the workers
# get postgres:5432 via the service network instead.
DATABASE_URL=postgres://scribeflow:scribeflow@localhost:55432/scribeflow

# Cloudflare R2 — same scoped token as the API's (read access is enough for
# workers). R2_ENDPOINT normally derives from the account id; set explicitly
# only for S3-compatible stand-ins.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scribeflow
R2_ENDPOINT=

# Groq (docs/infrastructure.md free-tier limits; calls go through the shared
# rate limiter, D24)
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# D22 fallback switch: groq | local. "local" runs LOCAL_WHISPER_CMD (a
# whisper.cpp-style CLI); {input} and {output_base} are substituted, and
# {output_base}.json must contain verbose_json-compatible output.
TRANSCRIBE_BACKEND=groq
LOCAL_WHISPER_CMD=

# Phase 3 (3.1/3.2, D21/D59): same Groq account/key as above, LLM model for
# action-item/decision/summary extraction and per-utterance sentiment.
# GROQ_LLM_RATE_PER_MIN is its own token-bucket bucket (rate_limiter.py) —
# Groq's free-tier limits are per-model, not shared with the Whisper quota.
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_LLM_RATE_PER_MIN=20

# Diarizer (D23): HF token needs the pyannote/speaker-diarization-3.1 (and
# its segmentation sub-model) license accepted on huggingface.co first.
HF_TOKEN=
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1

# Embedder (ticket 3.5, D63): CPU sentence-transformers, no API key needed.
# Must stay the sentence-transformers twin of api/.env.example's
# EMBEDDING_QUERY_MODEL — same weights, different runtime — or the RAG
# chat's query vectors land in a different space than the stored ones.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Nudger (ticket 3.8, D66): same Resend account as the API's summary/
# follow-up emails (api/.env.example), its own key here since this process
# doesn't share the API's. Leave blank to run with the daily scan logging
# candidates but sending no email (dashboard overdue styling still works
# either way — it reads existing due-date data, not this).
RESEND_API_KEY=
RESEND_FROM_EMAIL=ScribeFlow <notifications@scribeflow.deepcoomer.dev>

LOG_LEVEL=INFO
